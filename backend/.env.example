# Copiar este archivo a .env y completar con valores reales.
# .env NUNCA se sube a git (ver .gitignore).

SECRET_KEY=cambia-esto-por-una-clave-secreta-larga-y-aleatoria
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Si se deja vacio / sin definir, el proyecto cae a SQLite local automaticamente.
# En Railway apunta al Postgres gestionado (una URL distinta por servicio/barberia).
DATABASE_URL=postgres://user:password@localhost:5432/barberia_db

# Origenes exactos del frontend permitidos por CORS (sin "*" en produccion).
CORS_ALLOWED_ORIGINS=https://tu-frontend.pages.dev
# Solo para desarrollo local, nunca en produccion:
CORS_ALLOW_ALL_ORIGINS_DEV=False

# Resend (email de confirmacion). Si se deja vacio, los emails se imprimen
# en consola en vez de enviarse de verdad (util en desarrollo local).
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=reservas@tudominio.com

# Identidad de la barberia servida por ESTE despliegue (un despliegue = una
# barberia). Cambia estos valores por servicio de Railway / rama de deploy.
BARBERIA_NOMBRE="Legend Barbershop"
BARBERIA_SLUG=legendaria
BARBERIA_PERMITE_ELEGIR_BARBERO=True
BARBERIA_COLOR_PRIMARIO=#C9A961
